# Pstryk API (energy prices)
PSTRYK_API_KEY=sk-your-api-key

# Deye Cloud (inverter control)
DEYE_APP_ID=your-app-id
DEYE_APP_SECRET=your-app-secret
DEYE_EMAIL=your@email.com
DEYE_PASSWORD=your-password
DEYE_DEVICE_SN=your-device-serial

# Telegram bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Vercel Cron security
CRON_SECRET=your-cron-secret

# Vercel KV (auto-set when you create KV store in Vercel)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# PV installation location (required for forecast.solar fallback when Solcast unset)
PV_LAT=
PV_LON=
PV_POSTAL_CODE=
# PV_DEC=35         # Panel tilt in degrees (default 35)
# PV_AZ=0           # Azimuth: 0=south, -90=east, 90=west (default 0)
# PV_KWP=10         # Installation size in kWp (default 10)

# go-e Charger — OCPP 1.6J CSMS integration
# Run `npm run agent:ocpp` on a LAN-connected always-on host (e.g. Mac mini).
# In go-e app: Connection → OCPP → enable + URL: ws://<csms-host>:9220/ocpp/EM-CHARGER
OCPP_PORT=9220
# GOE_DEVICE_ID=298174              # 6-digit serial (optional, informational)

# Legacy go-e HTTP v2 agent (not used with OCPP path)
# GOE_LOCAL_URL=http://192.168.x.x
# GOE_API_TOKEN=
# GOE_POLL_MS=30000

# Optional overrides
# CRON_SCHEDULE=55 * * * *
# MAX_SELL_POWER=8000
